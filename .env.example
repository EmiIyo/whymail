# Copy this file to .env and fill in your Supabase project values.
# Get them from: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push public (VAPID) key. Generate a pair with:
#   npx web-push generate-vapid-keys --json
# Put the publicKey here and store the privateKey in the app_secrets table
# (name = 'vapid_private_key'). The public key is not secret.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
